{
  "name": "@grgmddn/os-transform",
  "version": "1.0.0",
  "description": "TypeScript port of OrdnanceSurvey/os-transform",
  "license": "MIT",
  "contributors": [
    {
      "name": "George Madden",
      "url": "https://github.com/grgmddn",
      "author": true
    }
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit",
    "coverage": "node --import tsx/esm --test --experimental-test-coverage",
    "format": "prettier --write src",
    "lint": "eslint src",
    "test": "node --import tsx/esm --test src/**/*.test.ts",
    "typecheck": "npm run check"
  },
  "peerDependencies": {
    "proj4": ">=2.20.8"
  },
  "peerDependenciesMeta": {
    "proj4": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/node": "latest",
    "eslint": "latest",
    "prettier": "latest",
    "proj4": "^2.20.8",
    "tsdown": "^0.21.10",
    "tsx": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "undici": "8.0.2"
  },
  "workspaces": [
    "examples"
  ],
  "@parcel/resolver-default": {
    "packageExports": true
  },
  "bugs": "https://github.com/grgmddn/os-transform/issues",
  "homepage": "https://github.com/grgmddn/os-transform",
  "repository": {
    "type": "git",
    "url": "https://github.com/grgmddn/os-transform.git"
  }
}
