{
  "name": "examples",
  "version": "1.0.0",
  "scripts": {
    "build": "parcel build ./*.html",
    "check": "tsc --noEmit",
    "dev:cgi": "parcel ./geojson-extent-ostn15-cgi.html",
    "dev:gsb": "parcel ./geojson-extent-ostn15-gsb.html",
    "dev:simple": "parcel ./geojson-extent-simple-towgs84.html",
    "dev:all": "parcel ./all.html",
    "dev:tif": "parcel ./geojson-extent-ostn15-tif.html",
    "format": "prettier --write \"*.html\" \"src/**/*.ts\"",
    "lint": "eslint src",
    "typecheck": "npm run check"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/node": "latest",
    "buffer": "^6.0.3",
    "eslint": "latest",
    "parcel": "^2.13.3",
    "parcel-reporter-static-files-copy": "^1.5.3",
    "prettier": "latest",
    "typescript": "^5.8.3",
    "typescript-eslint": "latest"
  },
  "dependencies": {
    "@grgmddn/os-transform": "file:..",
    "@turf/turf": "^7.3.5",
    "@types/d3": "^7.4.3",
    "d3": "^7.9.0",
    "geojson": "^0.5.0",
    "geotiff": "^2.0.7",
    "proj4": "^2.20.8"
  },
  "@parcel/resolver-default": {
    "packageExports": true
  }
}
