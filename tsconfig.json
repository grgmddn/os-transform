{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "lib": ["DOM", "ES2020"],
    "rootDir": "./src",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler"
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "dist"]
}
